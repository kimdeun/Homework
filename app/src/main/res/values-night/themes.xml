<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Базовая тема приложения -->
    <style name="Base.Theme.PlaylistMaker" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Базовые настройки -->
    </style>

    <!-- Основная тема приложения для темной темы -->
    <style name="Theme.PlaylistMaker" parent="Base.Theme.PlaylistMaker">
        <!-- Primary brand color (черный для статус-бара) -->
        <item name="colorPrimary">@color/black</item>

        <!-- Цвет текста на primary цвете -->
        <item name="colorOnPrimary">@color/white</item>

        <!-- Secondary цвет - БЕЛЫЙ для кнопок -->
        <item name="colorSecondary">@color/white</item>

        <!-- Цвет текста на secondary цвете - ЧЕРНЫЙ для кнопок -->
        <item name="colorOnSecondary">@color/black</item>

        <!-- Фон приложения -->
        <item name="android:windowBackground">@color/background_dark</item>

        <!-- Цвет статус бара -->
        <item name="android:statusBarColor">@color/black</item>

        <!-- Цвет навигационного бара -->
        <item name="android:navigationBarColor">@color/background_dark</item>

        <!-- Цвет основного текста -->
        <item name="android:textColorPrimary">@color/text_primary</item>

        <!-- Цвет второстепенного текста -->
        <item name="android:textColorSecondary">@color/icon_secondary</item>
    </style>
</resources>
<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_light"
    android:paddingHorizontal="@dimen/screen_padding"
    android:paddingTop="@dimen/title_margin_top">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="17dp"
            android:contentDescription="@string/main_media"
            android:src="@drawable/ic_arrow"
            app:tint="@color/text_dark" />

        <TextView
            android:id="@+id/tvTitle"
            style="@style/Text_TitleScreen"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/margin_12"
            android:text="@string/main_media" />
    </LinearLayout>

</LinearLayout>
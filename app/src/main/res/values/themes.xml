<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Базовая тема приложения -->
    <style name="Base.Theme.PlaylistMaker" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Базовые настройки -->
    </style>

    <!-- Основная тема приложения для темной темы -->
    <style name="Theme.PlaylistMaker" parent="Base.Theme.PlaylistMaker">
        <!-- Primary brand color (черный) -->
        <item name="colorPrimary">@color/black</item>

        <!-- Цвет текста на primary цвете -->
        <item name="colorOnPrimary">@color/white</item>

        <!-- Secondary цвет -->
        <item name="colorSecondary">@color/white</item>

        <!-- Цвет текста на secondary цвете -->
        <item name="colorOnSecondary">@color/black</item>

        <!-- Фон приложения - по умолчанию черный -->
        <item name="android:windowBackground">@color/black</item>

        <!-- Цвет статус бара -->
        <item name="android:statusBarColor">@color/black</item>

        <!-- Цвет навигационного бара -->
        <item name="android:navigationBarColor">@color/black</item>

        <!-- Цвет основного текста (по умолчанию белый для настроек) -->
        <item name="android:textColorPrimary">@color/white</item>

        <!-- Цвет второстепенного текста -->
        <item name="android:textColorSecondary">@color/white</item>

    </style>
</resources>
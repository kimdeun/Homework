<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ================= TEXT ================= -->

    <!-- Заголовки экранов (Settings / Agreement) -->
    <style name="Text_TitleScreen">
        <item name="android:fontFamily">@font/ys_display_medium</item>
        <item name="android:fontWeight">500</item>
        <item name="android:textColor">@color/text_dark</item>
        <item name="android:textSize">22sp</item>
    </style>

    <!-- Заголовок главного экрана -->
    <style name="Text_TitleMain">
        <item name="android:fontFamily">@font/ys_display_medium</item>
        <item name="android:fontWeight">500</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">24sp</item>
    </style>

    <!-- Пункты настроек -->
    <style name="Text_SettingsItem">
        <item name="android:fontFamily">@font/ys_display</item>
        <item name="android:fontWeight">400</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:minHeight">@dimen/settings_item_height</item>
        <item name="android:textColor">@color/text_dark</item>
        <item name="android:textSize">16sp</item>
    </style>

    <!-- Текст соглашения -->
    <style name="Text_AgreementBody">
        <item name="android:fontFamily">@font/ys_display</item>
        <item name="android:fontWeight">400</item>
        <item name="android:textColor">@color/text_dark</item>
        <item name="android:textSize">16sp</item>
        <item name="android:lineSpacingExtra">6dp</item>
    </style>

    <!-- ================= VIEWS ================= -->

    <!-- Иконки справа в настройках -->
    <style name="Icon_Settings">
        <item name="android:layout_width">@dimen/settings_icon_size</item>
        <item name="android:layout_height">@dimen/settings_icon_size</item>
        <item name="android:tint">@color/icon_secondary</item>
        <item name="android:contentDescription">@null</item>
    </style>

    <!-- Switch (Dark Theme) -->
    <style name="Switch_Settings">
        <item name="thumbTint">@color/switch_thumb_selector</item>
        <item name="trackTint">@color/switch_track_selector</item>
    </style>

    <!-- Кнопки-карточки на главном -->
    <style name="Button_MainCard" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">0dp</item>
        <item name="android:layout_weight">1</item>

        <item name="android:textAllCaps">false</item>

        <!-- без тени -->
        <item name="android:elevation">0dp</item>
        <item name="elevation">0dp</item>
        <item name="android:stateListAnimator">@null</item>

        <!-- внешний вид -->
        <item name="backgroundTint">@color/white</item>
        <item name="cornerRadius">@dimen/card_radius</item>

        <!-- текст/иконка -->
        <item name="android:textColor">@color/text_on_card</item>
        <item name="iconTint">@color/text_on_card</item>
        <item name="iconGravity">textStart</item>
        <item name="iconPadding">@dimen/main_icon_padding</item>

        <!-- шрифт -->
        <item name="android:fontFamily">@font/ys_display_medium</item>
        <item name="android:textSize">20sp</item>
    </style>

    <!-- ============== ALIASES ============== -->
    <style name="Text" parent="Text_TitleScreen" />
    <style name="Icon" parent="Icon_Settings" />
    <style name="Switch" parent="Switch_Settings" />

</resources>